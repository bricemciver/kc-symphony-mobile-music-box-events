{
  "name": "kc-symphony-mobile-music-box-events",
  "version": "0.0.1",
  "private": true,
  "description": "Read events from the KC Symphony Mobile Music Box webpage and format into JSON for programatic use.",
  "license": "MIT",
  "author": "Brice McIver (github@bricemciver.com)",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
