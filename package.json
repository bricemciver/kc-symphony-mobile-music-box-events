    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^24.10.9",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.1"
  }
}
